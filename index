    .pi-3 { background: linear-gradient(135deg, #2A3020 0%, #506030 50%, #90A060 100%); }
    .pi-4 { background: linear-gradient(135deg, #2A2040 0%, #504080 50%, #9080C0 100%); }
    .pi-5 { background: linear-gradient(135deg, #402020 0%, #804040 50%, #C47070 100%); }
    .pi-6 { background: linear-gradient(135deg, #403020 0%, #806040 50%, #C09060 100%); }
    .pi-7 { background: linear-gradient(135deg, #202840 0%, #405080 50%, #7090C0 100%); }
    .portfolio-item-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(74,44,42,0.9) 0%, transparent 60%);
      opacity: 0; transition: opacity 0.4s;
      display: flex; flex-direction: column; justify-content: flex-end; padding: 20px;
    }
    .portfolio-item:hover .portfolio-item-overlay { opacity: 1; }
    .portfolio-item-label { color: var(--white); font-family: 'Playfair Display', serif; font-size: 1rem; }
    .portfolio-item-tag { color: var(--gold); font-size: 0.75rem; letter-spacing: 0.06em; }
    .portfolio-item-zoom {
      position: absolute; top: 12px; right: 12px; width: 36px; height: 36px;
      background: rgba(255,255,255,0.15); backdrop-filter: blur(10px);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      color: white; font-size: 1rem;
      opacity: 0; transform: scale(0.8); transition: all 0.3s;
    }
    .portfolio-item:hover .portfolio-item-zoom { opacity: 1; transform: scale(1); }
    /* Henna SVG patterns inside portfolio items */
    .portfolio-henna-svg {
      position: absolute; inset: 0; width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      opacity: 0.5;
    }

    /* Lightbox */
    .lightbox {
      position: fixed; inset: 0; z-index: 2000;
      background: rgba(0,0,0,0.92); display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity 0.3s;
    }
    .lightbox.open { opacity: 1; pointer-events: all; }
    .lightbox-close {
      position: absolute; top: 24px; right: 24px;
      background: rgba(255,255,255,0.1); border: none; color: white;
      width: 44px; height: 44px; border-radius: 50%; font-size: 1.2rem;
      cursor: pointer; backdrop-filter: blur(10px); transition: background 0.3s;
    }
    .lightbox-close:hover { background: rgba(255,255,255,0.2); }
    .lightbox-content {
      width: 80vw; max-width: 700px; border-radius: 20px; overflow: hidden;
      box-shadow: 0 40px 100px rgba(0,0,0,0.6);
    }
    .lightbox-img { width: 100%; height: 500px; }

    /* ══════════════════════════════════════════
       WHY CHOOSE US
    ══════════════════════════════════════════ */
    #why { padding: 120px 0; background: var(--brown); position: relative; overflow: hidden; }
    .why-bg-pattern {
      position: absolute; inset: 0;
      background-image: radial-gradient(circle at 30% 50%, rgba(201,163,78,0.08) 0%, transparent 50%),
                        radial-gradient(circle at 70% 50%, rgba(196,138,138,0.06) 0%, transparent 40%);
    }
    #why .section-title { color: var(--ivory); }
    #why .section-tag { color: var(--gold); }
    #why .section-subtitle { color: rgba(250,247,242,0.7); }
    .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
    .why-card {
      background: rgba(255,255,255,0.05); border: 1px solid rgba(201,163,78,0.15);
      border-radius: 20px; padding: 36px 28px; text-align: center;
      transition: all 0.3s; backdrop-filter: blur(10px);
    }
    .why-card:hover {
      background: rgba(201,163,78,0.1); border-color: rgba(201,163,78,0.3);
      transform: translateY(-6px);
    }
    .why-icon {
      width: 70px; height: 70px; background: rgba(201,163,78,0.15);
      border-radius: 20px; display: flex; align-items: center; justify-content: center;
      font-size: 2rem; margin: 0 auto 24px; transition: background 0.3s;
    }
    .why-card:hover .why-icon { background: rgba(201,163,78,0.25); }
    .why-title { font-size: 1.1rem; color: var(--ivory); margin-bottom: 12px; }
    .why-desc { font-size: 0.88rem; color: rgba(250,247,242,0.6); line-height: 1.7; }

    /* ══════════════════════════════════════════
       PRICING
    ══════════════════════════════════════════ */
    #pricing { padding: 120px 0; background: var(--ivory-dark); }
    .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .pricing-card {
      background: var(--white); border-radius: 24px; padding: 44px 36px;
      box-shadow: var(--shadow-sm); position: relative; overflow: hidden;
      transition: all 0.3s;
    }
    .pricing-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
    .pricing-card.featured {
      background: var(--brown); box-shadow: 0 20px 60px rgba(74,44,42,0.35);
      transform: scale(1.04);
    }
    .pricing-card.featured:hover { transform: scale(1.04) translateY(-6px); }
    .pricing-card-bg {
      position: absolute; top: -60px; right: -60px; width: 200px; height: 200px;
      border-radius: 50%; background: rgba(201,163,78,0.06);
    }
    .pricing-badge {
      display: inline-block; padding: 4px 14px; border-radius: 50px;
      font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      background: var(--gold); color: var(--brown-dark); margin-bottom: 20px;
    }
    .pricing-tier { font-size: 0.8rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
    .pricing-name { font-size: 1.6rem; color: var(--brown); margin-bottom: 20px; }
    .pricing-card.featured .pricing-name { color: var(--ivory); }
    .pricing-price {
      font-family: 'Playfair Display', serif;
      font-size: 3rem; color: var(--brown); line-height: 1; margin-bottom: 8px;
    }
    .pricing-card.featured .pricing-price { color: var(--gold); }
    .pricing-price sup { font-size: 1.2rem; vertical-align: super; }
    .pricing-period { font-size: 0.82rem; color: var(--text-light); margin-bottom: 32px; }
    .pricing-card.featured .pricing-period { color: rgba(250,247,242,0.5); }
    .pricing-features { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-bottom: 36px; }
    .pricing-features li {
      font-size: 0.88rem; color: var(--text-mid); display: flex; align-items: center; gap: 10px;
    }
    .pricing-card.featured .pricing-features li { color: rgba(250,247,242,0.75); }
    .pricing-features li::before { content: '✓'; color: var(--gold); font-weight: 700; flex-shrink: 0; }
    .pricing-divider { height: 1px; background: var(--ivory-dark); margin: 24px 0; }
    .pricing-card.featured .pricing-divider { background: rgba(255,255,255,0.1); }
    .pricing-addons { font-size: 0.8rem; color: var(--text-light); margin-bottom: 32px; }
    .pricing-card.featured .pricing-addons { color: rgba(250,247,242,0.4); }
    .pricing-note { font-size: 0.78rem; color: var(--text-light); text-align: center; margin-top: 32px; }

    /* ══════════════════════════════════════════
       TESTIMONIALS
    ══════════════════════════════════════════ */
    #testimonials { padding: 120px 0; background: var(--ivory); overflow: hidden; }
    .testimonials-slider { position: relative; overflow: hidden; }
    .testimonials-track {
      display: flex; gap: 28px;
      transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);
    }
    .testimonial-card {
      flex: 0 0 calc(33.333% - 19px); min-width: 0;
      background: var(--white); border-radius: 24px; padding: 36px;
      box-shadow: var(--shadow-sm); position: relative;
    }
    .testimonial-quote { font-size: 4rem; color: var(--gold); line-height: 0.6; margin-bottom: 20px; font-family: serif; }
    .testimonial-text { font-size: 0.95rem; color: var(--text-mid); line-height: 1.8; margin-bottom: 28px; font-style: italic; }
    .testimonial-author { display: flex; align-items: center; gap: 14px; }
    .testimonial-avatar {
      width: 50px; height: 50px; border-radius: 50%;
      background: linear-gradient(135deg, var(--rose), var(--brown));
      display: flex; align-items: center; justify-content: center;
      color: white; font-weight: 700; font-size: 1.1rem; flex-shrink: 0;
    }
    .testimonial-name { font-weight: 600; color: var(--brown); font-size: 0.9rem; }
    .testimonial-role { font-size: 0.78rem; color: var(--text-light); }
    .testimonial-stars { color: var(--gold); font-size: 0.85rem; margin-bottom: 4px; }
    .slider-controls { display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 40px; }
    .slider-btn {
      width: 44px; height: 44px; border-radius: 50%; border: 1.5px solid var(--ivory-dark);
      background: var(--white); cursor: pointer; display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem; transition: all 0.3s; color: var(--text-mid);
    }
    .slider-btn:hover { background: var(--brown); color: var(--gold); border-color: var(--brown); }
    .slider-dots { display: flex; gap: 8px; }
    .slider-dot {
      width: 8px; height: 8px; border-radius: 50%; background: var(--ivory-dark);
      cursor: pointer; transition: all 0.3s;
    }
    .slider-dot.active { background: var(--gold); width: 24px; border-radius: 4px; }

    /* ══════════════════════════════════════════
       FAQ
    ══════════════════════════════════════════ */
    #faq { padding: 100px 0; background: var(--ivory-dark); }
    .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 60px; }
    .faq-item { border-bottom: 1px solid var(--ivory-dark); padding: 24px 0; }
    .faq-question {
      display: flex; justify-content: space-between; align-items: center;
      cursor: pointer; gap: 16px;
    }
    .faq-question h4 { font-size: 1rem; color: var(--brown); font-weight: 600; flex: 1; }
    .faq-toggle {
      width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--gold);
      display: flex; align-items: center; justify-content: center;
      color: var(--gold); font-size: 1rem; flex-shrink: 0;
      transition: all 0.3s;
    }
    .faq-item.open .faq-toggle { background: var(--gold); color: var(--brown-dark); transform: rotate(45deg); }
    .faq-answer {
      max-height: 0; overflow: hidden; transition: max-height 0.4s ease, padding 0.3s;
      font-size: 0.9rem; color: var(--text-mid); line-height: 1.75;
    }
    .faq-item.open .faq-answer { max-height: 200px; padding-top: 14px; }

    /* ══════════════════════════════════════════
       BOOKING SECTION
    ══════════════════════════════════════════ */
    #booking { padding: 120px 0; background: var(--ivory); }
    .booking-layout { display: grid; grid-template-columns: 1fr 1.4fr; gap: 60px; align-items: start; }
    .booking-info { }
    .booking-info p { color: var(--text-mid); line-height: 1.8; margin-bottom: 32px; }
    .booking-steps { display: flex; flex-direction: column; gap: 20px; }
    .booking-step { display: flex; gap: 16px; align-items: flex-start; }
    .booking-step-num {
      width: 36px; height: 36px; border-radius: 50%;
      background: var(--gold); color: var(--brown-dark);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.85rem; flex-shrink: 0;
    }
    .booking-step-text h4 { font-size: 0.95rem; color: var(--brown); margin-bottom: 4px; }
    .booking-step-text p { font-size: 0.85rem; color: var(--text-light); }

    .booking-form {
      background: var(--white); border-radius: 28px; padding: 48px;
      box-shadow: var(--shadow-md); position: relative; overflow: hidden;
    }
    .booking-form::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
      background: linear-gradient(90deg, var(--brown), var(--gold), var(--rose));
    }
    .form-progress { display: flex; gap: 0; margin-bottom: 36px; }
    .form-step-indicator {
      flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px;
      position: relative;
    }
    .form-step-indicator::after {
      content: ''; position: absolute; top: 14px; left: 50%; width: 100%;
      height: 2px; background: var(--ivory-dark); z-index: 0;
    }
    .form-step-indicator:last-child::after { display: none; }
    .step-circle {
      width: 28px; height: 28px; border-radius: 50%;
      background: var(--ivory-dark); color: var(--text-light);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.75rem; font-weight: 600; position: relative; z-index: 1;
      transition: all 0.3s;
    }
    .form-step-indicator.active .step-circle { background: var(--gold); color: var(--brown-dark); }
    .form-step-indicator.done .step-circle { background: var(--brown); color: var(--white); }
    .step-label { font-size: 0.7rem; color: var(--text-light); letter-spacing: 0.04em; }
    .form-step-indicator.active .step-label { color: var(--gold); }

    .form-panel { display: none; }
    .form-panel.active { display: block; }
    .form-group { margin-bottom: 20px; }
    .form-group label {
      display: block; font-size: 0.8rem; font-weight: 600;
      color: var(--text-mid); letter-spacing: 0.06em; margin-bottom: 8px; text-transform: uppercase;
    }
    .form-group input, .form-group select, .form-group textarea {
      width: 100%; padding: 14px 18px; border: 1.5px solid var(--ivory-dark);
      border-radius: 10px; font-family: 'Inter', sans-serif; font-size: 0.93rem;
      color: var(--text-dark); background: var(--ivory);
      transition: all 0.3s; outline: none; appearance: none;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
      border-color: var(--gold); background: var(--white);
      box-shadow: 0 0 0 3px rgba(201,163,78,0.12);
    }
    .form-group textarea { resize: vertical; min-height: 100px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-nav { display: flex; gap: 12px; margin-top: 28px; }
    .form-success {
      text-align: center; padding: 40px 20px; display: none;
    }
    .form-success-icon { font-size: 4rem; margin-bottom: 16px; }
    .form-success h3 { font-size: 1.5rem; color: var(--brown); margin-bottom: 12px; }
    .form-success p { color: var(--text-mid); }

    /* ══════════════════════════════════════════
       INSTAGRAM SECTION
    ══════════════════════════════════════════ */
    #instagram { padding: 100px 0; background: var(--brown-dark); }
    #instagram .section-title { color: var(--ivory); }
    #instagram .section-tag { color: var(--gold); }
    .instagram-grid {
      display: grid; grid-template-columns: repeat(6, 1fr); gap: 6px; margin-bottom: 40px;
    }
    .instagram-item {
      aspect-ratio: 1; border-radius: 8px; overflow: hidden;
      cursor: pointer; position: relative;
    }
    .instagram-bg {
      width: 100%; height: 100%; transition: transform 0.4s;
    }
    .instagram-item:hover .instagram-bg { transform: scale(1.08); }
    .ig-1 { background: linear-gradient(135deg, #5C3330, #C48A8A); }
    .ig-2 { background: linear-gradient(135deg, #3D2820, #C9A34E); }
    .ig-3 { background: linear-gradient(135deg, #2A2040, #9080C0); }
    .ig-4 { background: linear-gradient(135deg, #203040, #5090C0); }
    .ig-5 { background: linear-gradient(135deg, #402020, #C07070); }
    .ig-6 { background: linear-gradient(135deg, #402A10, #C09060); }
    .instagram-overlay {
      position: absolute; inset: 0; background: rgba(74,44,42,0.7);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity 0.3s; color: white; font-size: 1.3rem;
    }
    .instagram-item:hover .instagram-overlay { opacity: 1; }
    .instagram-handle {
      display: inline-flex; align-items: center; gap: 10px;
      background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
      color: var(--ivory); padding: 12px 24px; border-radius: 50px;
      font-size: 0.9rem; transition: all 0.3s; backdrop-filter: blur(10px);
    }
    .instagram-handle:hover { background: rgba(255,255,255,0.15); }

    /* ══════════════════════════════════════════
       CTA STRIP
    ══════════════════════════════════════════ */
    #cta-strip {
      padding: 100px 0; position: relative; overflow: hidden;
      background: linear-gradient(135deg, var(--brown-dark) 0%, var(--brown) 50%, #6B3F3C 100%);
    }
    .cta-strip-bg {
      position: absolute; inset: 0;
      background-image: radial-gradient(circle at 20% 50%, rgba(201,163,78,0.15) 0%, transparent 50%),
                        radial-gradient(circle at 80% 50%, rgba(196,138,138,0.1) 0%, transparent 40%);
    }
    .cta-strip-mandala {
      position: absolute; right: -100px; top: 50%; transform: translateY(-50%);
      width: 400px; height: 400px; border-radius: 50%;
      border: 60px solid rgba(201,163,78,0.06);
    }
    .cta-content { position: relative; z-index: 1; text-align: center; }
    .cta-tag { color: var(--gold-light); font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 16px; display: block; }
    .cta-headline { font-size: clamp(2rem, 4vw, 3.4rem); color: var(--white); margin-bottom: 16px; }
    .cta-sub { color: rgba(250,247,242,0.7); font-size: 1.05rem; max-width: 500px; margin: 0 auto 40px; }
    .cta-availability {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(201,163,78,0.15); border: 1px solid rgba(201,163,78,0.25);
      color: var(--gold-light); padding: 8px 18px; border-radius: 50px;
      font-size: 0.78rem; margin-bottom: 32px;
    }
    .cta-dot { width: 6px; height: 6px; border-radius: 50%; background: #4CAF50; animation: pulse 2s infinite; }

    /* ══════════════════════════════════════════
       CONTACT
    ══════════════════════════════════════════ */
    #contact { padding: 120px 0; background: var(--ivory-dark); }
    .contact-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 60px; }
    .contact-info { }
    .contact-card {
      display: flex; gap: 16px; padding: 20px; background: var(--white);
      border-radius: 16px; box-shadow: var(--shadow-sm); margin-bottom: 16px;
    }
    .contact-icon {
      width: 44px; height: 44px; border-radius: 12px;
      background: var(--ivory-dark); display: flex; align-items: center;
      justify-content: center; font-size: 1.2rem; flex-shrink: 0;
    }
    .contact-detail h4 { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-light); margin-bottom: 4px; }
    .contact-detail p { font-size: 0.93rem; color: var(--brown); font-weight: 500; }
    .contact-social { display: flex; gap: 12px; margin-top: 28px; }
    .social-btn {
      width: 44px; height: 44px; border-radius: 12px;
      background: var(--white); border: 1.5px solid var(--ivory-dark);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem; cursor: pointer; transition: all 0.3s;
    }
    .social-btn:hover { background: var(--brown); border-color: var(--brown); color: var(--gold); }
    .whatsapp-btn {
      display: inline-flex; align-items: center; gap: 10px;
      background: #25D366; color: white; padding: 14px 28px; border-radius: 50px;
      font-weight: 600; font-size: 0.9rem; margin-top: 20px;
      transition: all 0.3s; box-shadow: 0 4px 20px rgba(37,211,102,0.35);
    }
    .whatsapp-btn:hover { background: #1EBE5B; transform: translateY(-2px); }
    .map-embed {
      height: 220px; border-radius: 16px; overflow: hidden;
      background: linear-gradient(135deg, var(--ivory-dark), var(--ivory));
      display: flex; align-items: center; justify-content: center;
      margin-top: 20px; border: 2px solid var(--ivory-dark);
      position: relative;
    }
    .map-placeholder { text-align: center; color: var(--text-light); }
    .contact-form {
      background: var(--white); border-radius: 28px; padding: 44px;
      box-shadow: var(--shadow-md);
    }
    .contact-form h3 { font-size: 1.6rem; color: var(--brown); margin-bottom: 28px; }

    /* ══════════════════════════════════════════
       FOOTER
    ══════════════════════════════════════════ */
    #footer { background: var(--brown-dark); color: rgba(250,247,242,0.7); }
    .footer-top {
      padding: 80px 0 60px;
      display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 48px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .footer-brand p { font-size: 0.88rem; line-height: 1.8; margin: 20px 0 28px; max-width: 300px; }
    .footer-logo { color: var(--ivory); }
    .footer-newsletter { display: flex; gap: 0; }
    .newsletter-input {
      flex: 1; padding: 12px 16px; background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12); border-right: none;
      border-radius: 8px 0 0 8px; color: var(--ivory); font-size: 0.88rem;
      outline: none; transition: border-color 0.3s;
    }
    .newsletter-input:focus { border-color: var(--gold); }
    .newsletter-input::placeholder { color: rgba(250,247,242,0.3); }
    .newsletter-btn {
      padding: 12px 20px; background: var(--gold); color: var(--brown-dark);
      border: none; border-radius: 0 8px 8px 0; font-weight: 600; font-size: 0.83rem;
      cursor: pointer; transition: background 0.3s; white-space: nowrap;
    }
    .newsletter-btn:hover { background: var(--gold-light); }
    .footer-col h4 { color: var(--ivory); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-links a { font-size: 0.88rem; transition: color 0.3s; }
    .footer-links a:hover { color: var(--gold); }
    .footer-bottom {
      padding: 24px 0; display: flex; align-items: center; justify-content: space-between;
    }
